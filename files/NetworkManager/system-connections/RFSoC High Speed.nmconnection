[connection]
id=RFSoC High Speed (en2)
type=ethernet
autoconnect-priority=10
autoconnect-retries=0
interface-name=en2

[ethernet]
mtu=9000

[ethtool]
ring-rx=4096
ring-tx=4096

[ipv4]
address1=192.168.4.1/24
method=manual
never-default=true

[ipv6]
addr-gen-mode=stable-privacy
method=ignore

[proxy]
