[Unit]
Description=Analog Frontend controller service
BindsTo=dev-ttyGNSS1.device
After=dev-ttyGNSS1.device
BindsTo=gpsd.service
After=gpsd.service

[Service]
Type=exec
ExecStart=/opt/radiohound/python313/bin/python /opt/afe/afe_service.py
User=mep
Group=mep
Restart=always

[Install]
WantedBy=multi-user.target
